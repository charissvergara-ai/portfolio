generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  products  Product[]
  orders    Order[]
  createdAt DateTime @default(now())
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  price       Float
  salePrice   Float?
  image       String
  rating      Float      @default(0)
  downloads   Int        @default(0)
  category    Category   @relation(fields: [categoryId], references: [id])
  categoryId  String
  vendor      User       @relation(fields: [vendorId], references: [id])
  vendorId    String
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  deletedAt   DateTime?
}

model Order {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  total     Float
  status    OrderStatus @default(PENDING)
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  price     Float
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
